{
  "authSessions": {
    "enabled": true,
    "type": "API"
  },
  "replication": {
    "size": "standard",
    "maxCount": 1
  },
  "metadata": {
    "template": {
      "name": "e-commerce-auth-scrapingcourse",
      "description": "E-commerce scraper with authentication using scrapingcourse.com",
      "tags": ["scraping", "e-commerce", "auth-sessions"]
    },
    "defaultRunPlaygroundInput": {
      "apiName": "list",
      "parameters": {}
    }
  },
  "version": "2.0"
}
