// For more information, see our Intuned settings reference
// https://intunedhq.com/docs/main/05-references/intuned-json
{
  "authSessions": {
    "enabled": false,
  },
  "replication": {
    "size": "standard",
    "maxCount": 1,
    "minCount": 0,
  },
  "metadata": {
    "template": {
      "name": "e-commerce-shopify",
      "description": "Shopify store product scraper",
      "tags": ["scraping", "e-commerce"],
    },
    "defaultRunPlaygroundInput": {
      "apiName": "shopify-list",
      "parameters": {
        "store_url": "https://the-outrage.com",
        "maxPages": 10,
      },
    },
  },
  "version": "2.0",
}
