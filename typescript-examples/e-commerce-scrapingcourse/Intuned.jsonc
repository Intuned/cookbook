{
  "authSessions": {
    "enabled": false
  },
  "replication": {
    "size": "standard",
    "maxCount": 1,
    "minCount": 0
  },
  "metadata": {
    "template": {
      "name": "e-commerce-scrapingcourse",
      "description": "Basic e-commerce scraper using scrapingcourse.com",
      "tags": ["scraping", "e-commerce"]
    },
    "defaultRunPlaygroundInput": {
      "apiName": "list",
      "parameters": {
        "limit": 10
      }
    }
  },
  "version": "2.0"
}
