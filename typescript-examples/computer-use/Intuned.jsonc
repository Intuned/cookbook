// For more information, see our Intuned settings reference
// https://intunedhq.com/docs/main/05-references/intuned-json
{
  "authSessions": {
    "enabled": false
  },
  "replication": {
    "size": "standard",
    "maxCount": 1
  },
  "metadata": {
    "template": {
      "name": "computer-use",
      "description": "AI-powered browser automation using computer use capabilities from multiple providers",
      "tags": ["computer-use", "stagehand"]
    },
    "defaultRunPlaygroundInput": {
      "apiName": "anthropic-computer-use",
      "parameters": {
        "query": "Go to https://books.toscrape.com, navigate to the Science Fiction category, and list the top 5 books with their prices"
      }
      
    }
  },
  "version": "2.0"
}