// For more information, see our Intuned settings reference
// https://intunedhq.com/docs/main/05-references/intuned-json
{
  "authSessions": {
    "enabled": false
  },
  "replication": {
    "size": "standard",
    "maxCount": 1,
    "minCount": 0
  },
  "metadata": {
    "template": {
      "name": "starter-scrapy",
      "description": "Minimal Scrapy starter",
      "tags": [
        "starter",
        "scraping"
      ]
    },
    "defaultRunPlaygroundInput": {
      "apiName": "sample-scrapy-crawler",
      "parameters": {
        "url": "https://quotes.toscrape.com/"
      }
    }
  },
  "version": "2.0"
}
