// For more information, see our Intuned settings reference
// https://intunedhq.com/docs/main/05-references/intuned-json
{
  "authSessions": {
    "enabled": false,
  },
  "replication": {
    "size": "standard",
    "maxCount": 1,
    "minCount": 0,
  },
  "metadata": {
    "template": {
      "name": "bs4",
      "description": "Web scraping example using BeautifulSoup4 for HTML parsing",
      "tags": ["scraping"],
    },
    "defaultRunPlaygroundInput": {
      "apiName": "list",
      "parameters": {
        "url": "https://www.scrapingcourse.com/ecommerce/",
        "max_pages": 2,
      },
    },
  },
  "version": "2.0",
}
